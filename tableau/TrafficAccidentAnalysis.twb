            <map to='#bab0ac'>
              <bucket>&quot;EQUIPMENT - VEHICLE CONDITION&quot;</bucket>
            </map>
            <map to='#d37295'>
              <bucket>&quot;DISREGARDING YIELD SIGN&quot;</bucket>
            </map>
            <map to='#d37295'>
              <bucket>&quot;EVASIVE ACTION DUE TO ANIMAL, OBJECT, NONMOTORIST&quot;</bucket>
